// Rules updated
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Validation Helper
    function isValidLocation(data) {
      return data.keys().hasAll(['type', 'lat', 'lng', 'title', 'description', 'createdAt'])
        && (data.type in ['shelter', 'affected_zone', 'donation', 'transport', 'wifi', 'missing_person', 'collection_center'])
        && data.lat is number
        && data.lng is number
        && data.title is string && data.title.size() > 0 && data.title.size() <= 200
        && data.description is string && data.description.size() > 0 && data.description.size() <= 2000
        && data.createdAt is number
        && (!('contact' in data) || (data.contact is string && data.contact.size() <= 100))
        && (!('capacity' in data) || (data.capacity is number && data.capacity >= 1 && data.capacity <= 1000))
        && (!('donationCategory' in data) || (data.donationCategory is string))
        && (!('photo' in data) || (data.photo is string))
        && (!('status' in data) || (data.status is string))
        && (!('address' in data) || (data.address is string));
    }

    match /locations/{locationId} {
      // Allow anyone to read the locations
      allow read: if true;
      
      // Allow anyone to create a location if it matches the schema
      allow create: if isValidLocation(request.resource.data);
      
      // Allow updates to change status
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);
      
      allow delete: if false;
    }

    match /claims/{claimId} {
      // Allow anyone to create a claim
      allow create: if true; // Basic rule for now, can be hardened
      
      allow read, update, delete: if false;
    }
  }
}
// force sync
